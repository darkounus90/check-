# .env.example — CHECK (raíz)
# Copia a .env y completa. Nunca commitees .env (está en .gitignore).
# Cada app valida su propio entorno con Zod (ver apps/*/src/env.ts).

# ── apps/api ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── apps/workers ──────────────────────────────────────────
# Cola de trabajos (BullMQ + Redis / Upstash). Requerida desde la Épica 5.
# REDIS_URL=redis://localhost:6379
# WhatsApp (Baileys, Épica 7 Grupo A): instancia de un número con sesión en Postgres.
# WHATSAPP_ENABLED=true requiere WHATSAPP_WA_NUMBER_ID (id de la fila WaNumber).
# WHATSAPP_ENABLED=false
# WHATSAPP_WA_NUMBER_ID=
# Puerto del endpoint HTTP de salud/métricas de los workers (Épica 11, E11-T8).
# HEALTH_PORT=3002

# ── Observabilidad — Épica 11 (apps/api + apps/workers) ────
# Canal de alertas del equipo. Si ALERT_WEBHOOK_URL falta, las alertas se loguean en JSON
# (nunca se pierden) pero no salen a un canal externo. ALERT_WEBHOOK_STYLE: slack|discord.
# ALERT_WEBHOOK_URL=
# ALERT_WEBHOOK_STYLE=slack
# Umbrales del monitor de colas BullMQ (E11-T5), solo apps/workers.
# QUEUE_MONITOR_INTERVAL_MS=60000
# QUEUE_MONITOR_MAX_WAITING=100
# QUEUE_MONITOR_MAX_FAILED=20
# QUEUE_MONITOR_MAX_OLDEST_MS=300000

# ── Hardening / cumplimiento — Épica 12 (apps/api + apps/workers) ──
# Clave(s) de cifrado en reposo (E12-T1/T2). Cifra ocrText, WaSession.authState y artefactos.
# Formato: `v<n>:<base64-32B>` separadas por coma; la mayor versión es la ACTIVA (cifra) y el
# resto solo descifra ⇒ rotación SIN pérdida de datos. Genera una clave con:
#   node -e "console.log('v1:'+require('crypto').randomBytes(32).toString('base64'))"
# Rotación (E12-T2): añade v2 como activa `ENCRYPTION_KEYS=v2:<nueva>,v1:<vieja>`, recifra los
# sobres viejos (reencrypt) y, cuando ya no quede ninguno bajo v1, quita v1. Si falta la var, el
# cifrado a nivel de aplicación queda DESACTIVADO (solo aceptable en dev). En prod es obligatorio.
# ENCRYPTION_KEYS=v1:REEMPLAZA_CON_32_BYTES_BASE64
# Retención (E12-T3, solo apps/workers). Días por tipo; si faltan, caen a los defaults de
# @check/shared (voucher 365, bankEmail 365, qrResolutionLog 180, waSession 90).
# RETENTION_VOUCHER_DAYS=365
# RETENTION_BANK_EMAIL_DAYS=365
# RETENTION_QR_LOG_DAYS=180
# RETENTION_WA_SESSION_DAYS=90
# RETENTION_PURGE_INTERVAL_MS=86400000

# ── apps/web (Next.js) ────────────────────────────────────
# Variables públicas expuestas al navegador deben ir con prefijo NEXT_PUBLIC_.
# Base URL del API público (apps/api). Default de desarrollo: puerto 3001.
NEXT_PUBLIC_API_URL=http://localhost:3001
# Auth del dashboard (Épica 10, E10-T1/T2): cliente Supabase en el navegador y en
# el servidor (@supabase/ssr, cookies httpOnly). La anon key es pública por diseño;
# el aislamiento por negocio lo garantiza la RLS + la API (JWT del usuario), no la key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Servicios externos (se cablean en próximas épicas) ────
# DATABASE_URL=            # Supabase Postgres (Épica 2)
# SUPABASE_URL=            # Supabase Auth (Épica 3)
# SUPABASE_ANON_KEY=
# POSTMARK_SERVER_TOKEN=   # Correo entrante (Épica 4)
# GOOGLE_APPLICATION_CREDENTIALS=  # Google Cloud Vision (Épica 5)
