# .env.example — CHECK (raíz)
# Copia a .env y completa. Nunca commitees .env (está en .gitignore).
# Cada app valida su propio entorno con Zod (ver apps/*/src/env.ts).

# ── apps/api ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── apps/workers ──────────────────────────────────────────
# Cola de trabajos (BullMQ + Redis / Upstash). Requerida desde la Épica 5.
# REDIS_URL=redis://localhost:6379

# ── apps/web (Next.js) ────────────────────────────────────
# Variables públicas expuestas al navegador deben ir con prefijo NEXT_PUBLIC_.
# NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Servicios externos (se cablean en próximas épicas) ────
# DATABASE_URL=            # Supabase Postgres (Épica 2)
# SUPABASE_URL=            # Supabase Auth (Épica 3)
# SUPABASE_ANON_KEY=
# POSTMARK_SERVER_TOKEN=   # Correo entrante (Épica 4)
# GOOGLE_APPLICATION_CREDENTIALS=  # Google Cloud Vision (Épica 5)
