# apps/web (Next.js) — variables públicas con prefijo NEXT_PUBLIC_
# NEXT_PUBLIC_API_URL=http://localhost:3001
# Fallback opcional (E10-T3): opaqueId del negocio para habilitar la subida autenticada
# reutilizando la ruta pública mientras no exista un endpoint de vouchers autenticado.
# Útil en despliegues de un solo negocio o entornos de demo.
# NEXT_PUBLIC_BUSINESS_OPAQUE_ID=
