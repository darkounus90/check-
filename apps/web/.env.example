# apps/web (Next.js) — variables públicas con prefijo NEXT_PUBLIC_
# NEXT_PUBLIC_API_URL=http://localhost:3001
# La ruta pública /n/{opaqueId} es el ENRUTADOR de QR (Épica 8): server-side consulta
# GET /public/n/:opaqueId/route y redirige a wa.me si hay número sano, o cae a la PWA de
# subida (Épica 9). El dominio del QR se configura en apps/api con PUBLIC_APP_URL.
# La subida autenticada del dashboard usa POST /vouchers (el negocio se resuelve por el JWT),
# así que NO requiere configurar el opaqueId del negocio.
