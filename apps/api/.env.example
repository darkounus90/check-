# apps/api — variables de entorno (validadas en src/env.ts)
NODE_ENV=development
PORT=3001

# Supabase (Épica 3)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<secret>   # Admin API (crear usuarios/cajeros) — NO commitear

# Base de datos (Prisma / Épica 2)
DATABASE_URL=postgresql://...        # transaction pooler

# Buzón entrante (Épica 3/4) — dominio configurable (D1/D2)
INBOUND_EMAIL_DOMAIN=inbound.check.local

# Redis / BullMQ (Épica 9, E09-T4) — misma instancia que apps/workers
REDIS_URL=redis://localhost:6379

# Dominio público del enrutador de QR / PWA (Épica 8) — configurable por despliegue (D1).
# El QR imprimible de cada negocio apunta a ${PUBLIC_APP_URL}/n/{opaqueId}.
PUBLIC_APP_URL=http://localhost:3000

# Cifrado en reposo (Épica 12, E12-T1/T2). Ver .env.example de la raíz para el detalle de
# formato y rotación. Genera: node -e "console.log('v1:'+require('crypto').randomBytes(32).toString('base64'))"
# ENCRYPTION_KEYS=v1:REEMPLAZA_CON_32_BYTES_BASE64
