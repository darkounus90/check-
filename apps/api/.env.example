# apps/api — variables de entorno (validadas en src/env.ts)
NODE_ENV=development
PORT=3001

# Supabase (Épica 3)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<secret>   # Admin API (crear usuarios/cajeros) — NO commitear

# Base de datos (Prisma / Épica 2)
DATABASE_URL=postgresql://...        # transaction pooler

# Buzón entrante (Épica 3/4) — dominio configurable (D1/D2)
INBOUND_EMAIL_DOMAIN=inbound.check.local

# Redis / BullMQ (Épica 9, E09-T4) — misma instancia que apps/workers
REDIS_URL=redis://localhost:6379
