# apps/workers — variables de entorno (validadas en src/env.ts)
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/check
# Requerida desde la Épica 5 (E05-T3, BullMQ). Deuda pendiente: no hay Upstash real todavía.
REDIS_URL=redis://localhost:6379
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change-me

# WhatsApp (Baileys) — Épica 7, Grupo A. Instancia de un número con auth-state en Postgres.
# WHATSAPP_ENABLED=false: los workers corren solo OCR/verificación (sin WhatsApp).
# WHATSAPP_ENABLED=true requiere WHATSAPP_WA_NUMBER_ID (id de la fila WaNumber que esta
# instancia representa). Un número/instancia por proceso por ahora (multi-instancia es E07-T7).
# El QR de vinculación inicial se emite por log del WhatsAppManager (escanéalo la 1ª vez).
WHATSAPP_ENABLED=false
WHATSAPP_WA_NUMBER_ID=

# ── Hardening / cumplimiento (Épica 12) ──────────────────────────────
# Cifrado en reposo (E12-T1/T2): cifra WaSession.authState y artefactos de comprobante.
# Debe COINCIDIR con el ENCRYPTION_KEYS de apps/api (la BD es compartida). Ver la raíz para
# el formato y la rotación. Genera: node -e "console.log('v1:'+require('crypto').randomBytes(32).toString('base64'))"
# ENCRYPTION_KEYS=v1:REEMPLAZA_CON_32_BYTES_BASE64
# Retención (E12-T3): días por tipo. Si faltan, caen a los defaults de @check/shared.
# RETENTION_VOUCHER_DAYS=365
# RETENTION_BANK_EMAIL_DAYS=365
# RETENTION_QR_LOG_DAYS=180
# RETENTION_WA_SESSION_DAYS=90
# RETENTION_PURGE_INTERVAL_MS=86400000
